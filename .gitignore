# Heavy training images — under training/dataset/ only rotation_annotations.json is tracked
training/dataset/maps/
training/dataset/boundary_masks/
training/outputs/

# Cached out-of-fold predictions — regenerable via training/eval/
training/eval/predictions/

# Human boundary annotations
boundary_annotations/
