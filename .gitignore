# Annotation datasets (training data)
boundary_annotation_dataset/
boundary_annotation_curated/
boundary_annotation_v2_auto/

# boundary_annotation_v3/: the annotation tool's working dir. Keep the
# user's saved edits (edited.json / edited_mask.png) tracked; ignore the
# regeneratable bulk (map.png ~10-32 MB each, initial.json ~100 KB each).
boundary_annotation_v3/*/map.png
boundary_annotation_v3/*/initial.json
road_annotation_dataset/

# Claude Code internal state
.claude/

# External clones (kept locally, large)

# overnight/ is local scratch — experiments, research notes, debug dumps.
# Nothing in here needs to be in the public repo.
overnight/

# Evaluation data
evaluation_data/*

# IoU-split case folders (derived from benchmark results, not source)
cases_iou_below_*/
cases_iou_at_or_above_*/
verifier_dataset/

# loftr_probe experiment — generated data + weights, easy to nuke
experiments/loftr_probe/pairs/
experiments/loftr_probe/outputs/

# sam3_v8_replay experiment outputs (easy to nuke)
experiments/sam3_v8_replay/results.*


# Renamed dirs (post 2026-05-14 reorg)
# boundary_annotations/ replaces the v3 path; same selective-tracking pattern
# (keep edited.json + edited_mask.png; ignore map.png + initial.json).
boundary_annotations/*/map.png
boundary_annotations/*/initial.json
boundary_annotations/*/initial.json.bak

# training/dataset/ replaces dataset_v6/. Heavy PNGs; only keep manifests.
training/dataset/maps/
training/dataset/boundary_masks/

# More experiment-output gitignores
experiments/sam3_v8_replay/regression_renders/
experiments/sam3_v8_replay/augmentation_samples/
experiments/inspire_snap_results.json

# OML road index/geometry — large (423MB / 41MB), regenerable via
# tools/build_oml_road_index.py from OS OpenMap Local source data.
tools/oml_road_index.json
tools/oml_road_geom_subset.json

# Geocoder/websearch caches — regenerable, no in-repo consumer reads them.
tools/data/

# External clones (mast3r etc.) — large third-party repos, local only
external/
