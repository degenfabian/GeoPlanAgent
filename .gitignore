.env
.env.local
.env.*.local
.venv/*
.ruff_cache/*
__pycache__/
*.DS_Store

# Results and caches
results/
cache/
*_results/
*_cache/
llm_cache_v2/
llm_cache_v2_sam3_viz/
os_tile_cache/
osm_tile_cache/
os_opendata/

# Log files
*.log
*.out

# External dependency repo (cloned, not part of this project)
MINIMA/

# Model weights — only the multi-GB .pt files are ignored. Track everything
# else under models/: README, cv_summary.{json,csv}, per-fold history.json,
# fold_assignment.json, kfold_summary.json. These total ~70 KB and let a
# reviewer cloning the repo recompute the paper table without the .pt files.
# PEFT-format adapters (adapter_model.safetensors) are also ignored — they're
# multi-MB binary artifacts intended for separate release.
models/**/*.pt
models/**/*.safetensors

# Training scratch dirs — never committed; future runs may populate any of
# these. Keep the prophylactic ignores so a quick training experiment doesn't
# accidentally stage gigabytes of intermediate state.
training/outputs/
training/synthetic_data/
training/controlnet_data/
training/data/

# Claude Code internal state
.claude/

# overnight/ is local scratch — experiments, research notes, debug dumps.
# Nothing in here needs to be in the public repo.
overnight/

# Evaluation data
evaluation_data/*

# IoU-split case folders (derived from benchmark results, not source)
cases_iou_below_*/
cases_iou_at_or_above_*/
verifier_dataset/

# boundary_annotations/: keep the user's saved edits tracked (edited.json
# + edited_mask.png); ignore the regeneratable bulk (map.png ~10-32 MB
# each, initial.json ~100 KB each).
boundary_annotations/*/map.png
boundary_annotations/*/initial.json
boundary_annotations/*/initial.json.bak

# training/dataset/: heavy PNGs; only keep manifests
# (fold_assignment.json, rotation_annotations.json) tracked.
training/dataset/maps/
training/dataset/boundary_masks/

# OML road index/geometry — large (423MB / 41MB), regenerable via
# tools/build_oml_road_index.py from OS OpenMap Local source data.
tools/oml_road_index.json
tools/oml_road_geom_subset.json
