*.log
*.out

# External dependency repos (cloned, not part of this project)
MapSAM/
MapSAM2/
MINIMA/
MatchAnything/

# Model weights (large files)
models/
training/outputs/
training/synthetic_data/
training/controlnet_data/
training/data/
